# === OmniCore Environment Configuration ===

# LLM Provider (gemini or groq)
LLM_PROVIDER=gemini

# Google Gemini API Key (required when provider=gemini)
GOOGLE_API_KEY=your-google-api-key-here

# Gemini Model
OMNI_LLM_MODEL=gemini-1.5-pro

# Groq API Key (required when provider=groq)
GROQ_API_KEY=your-groq-api-key-here

# Optional multi-key round-robin pool (preferred over GROQ_API_KEY when set)
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# Groq model chain (Hydra 3-Tier fallback)
GROQ_PRIMARY_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODEL_1=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL_2=mixtral-8x7b-32768

# Legacy Groq model variables (backward compatibility)
GROQ_LLM_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile,mixtral-8x7b-32768

# Telegram Bot Token (required for Telegram gateway)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Allowed Telegram user IDs (comma-separated, leave empty to allow all)
TELEGRAM_ALLOWED_USERS=

# HITL Guardian timeout in minutes
HITL_TIMEOUT_MINUTES=5

# Hybrid CLI->GUI fallback controls (V24)
HYBRID_FALLBACK_ENABLED=true
HYBRID_FALLBACK_MAX_STEPS=4

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chromadb

# SQLite database path
SQLITE_DB_PATH=./data/omnicore.db

# Logging level
LOG_LEVEL=INFO

# Scheduler enabled
SCHEDULER_ENABLED=true
